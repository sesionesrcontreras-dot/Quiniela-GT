# ───────────────────────────────────────────────────────────
#  Copia este archivo a ".env" y rellena los valores.
#  NUNCA subas ".env" al repositorio (ya esta en .gitignore).
# ───────────────────────────────────────────────────────────

# Base de datos PostgreSQL (producción y local).
#  - Crea una gratis en Neon (https://neon.tech) o Supabase.
#  - Copia el "connection string" e incluye ?sslmode=require
#    Ejemplo:
#    DATABASE_URL="postgresql://usuario:clave@ep-xxx.us-east-2.aws.neon.tech/quiniela?sslmode=require"
DATABASE_URL="postgresql://USUARIO:CLAVE@HOST/quiniela?sslmode=require"

# Secreto para firmar sesiones (JWT). Genera uno fuerte:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET="CAMBIA_ESTO_por_un_secreto_largo_y_aleatorio"

# URL pública del sitio (en Netlify: https://TU-SITIO.netlify.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Procesador de tarjetas PAGGO (rellenar cuando contrates) ──
PAGGO_API_KEY=""
PAGGO_WEBHOOK_SECRET=""

# Comisión por defecto de la plataforma (rake) en porcentaje
DEFAULT_RAKE_PERCENT="12"
